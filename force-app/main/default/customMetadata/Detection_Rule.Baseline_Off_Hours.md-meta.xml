<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <label>Baseline Off Hours</label>
    <protected>false</protected>
    <values>
        <field>Apex_Class__c</field>
        <value xsi:type="xsd:string">Rule_BaselineOffHours</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Baseline Deviation</value>
    </values>
    <values>
        <field>Default_Risk_Score__c</field>
        <value xsi:type="xsd:double">25.0</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Flags successful logins occurring at an hour of day that represents less than two percent of the user's historical activity. Off-hours logins often indicate attacker access from a different time zone using stolen credentials. Low severity because off-hours work is common and benign in isolation.</value>
    </values>
    <values>
        <field>Is_Active__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>Remediation_Guidance__c</field>
        <value xsi:type="xsd:string">Triage in batches. If multiple off-hours findings cluster around the same user, correlate with country and IP baselines for stronger signal. For isolated findings, confirm with the user during their next normal-hours session.</value>
    </values>
    <values>
        <field>Required_Capability__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Run_Frequency__c</field>
        <value xsi:type="xsd:string">Every Run</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Low</value>
    </values>
</CustomMetadata>
