<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <label>New ConnectedApp Broad Scope</label>
    <protected>false</protected>
    <values>
        <field>Apex_Class__c</field>
        <value xsi:type="xsd:string">Rule_NewConnectedAppBroadScope</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">OAuth Risk</value>
    </values>
    <values>
        <field>Default_Risk_Score__c</field>
        <value xsi:type="xsd:double">75.0</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Flags newly observed connected apps that request broad OAuth scopes (api, refresh_token, full, web). A new third-party app with these scopes can read or modify nearly any data the installing user can see, so each one should be reviewed and either approved or blocked.</value>
    </values>
    <values>
        <field>Is_Active__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>Remediation_Guidance__c</field>
        <value xsi:type="xsd:string">Open the Connected App in Setup. Confirm with the installer that the app is legitimate and required. If not, revoke active tokens, block the app, and inform the installer. Document the approval in the finding's resolution notes.</value>
    </values>
    <values>
        <field>Required_Capability__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Run_Frequency__c</field>
        <value xsi:type="xsd:string">Every Run</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">High</value>
    </values>
</CustomMetadata>
