<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <label>Failed Login Burst</label>
    <protected>false</protected>
    <values>
        <field>Apex_Class__c</field>
        <value xsi:type="xsd:string">Rule_FailedLoginBurst</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Login Anomaly</value>
    </values>
    <values>
        <field>Default_Risk_Score__c</field>
        <value xsi:type="xsd:double">50.0</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Detects source IP addresses producing a burst of failed LoginHistory rows in the past hour. A high concentration of failures from one IP is a strong indicator of a password-spray or brute-force attempt against multiple users.</value>
    </values>
    <values>
        <field>Is_Active__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>Remediation_Guidance__c</field>
        <value xsi:type="xsd:string">Confirm the source IP is not a known corporate egress or test harness. If it is hostile, add the IP range to Network Access restrictions and notify any users whose accounts were targeted. Review their LoginHistory for successful logins from the same IP.</value>
    </values>
    <values>
        <field>Required_Capability__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Run_Frequency__c</field>
        <value xsi:type="xsd:string">Every Run</value>
    </values>
    <values>
        <field>Severity__c</field>
        <value xsi:type="xsd:string">Medium</value>
    </values>
</CustomMetadata>
