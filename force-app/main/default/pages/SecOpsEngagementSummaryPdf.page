<apex:page controller="EngagementSummaryPdfController"
           renderAs="pdf"
           applyHtmlTag="false"
           showHeader="false"
           standardStylesheets="false">
    <html>
        <head>
            <title>SecOps Engagement Summary</title>
            <style>
                body { font-family: Arial, sans-serif; font-size: 11pt; color: #1A3A5C; }
                h1 { color: #1A3A5C; border-bottom: 2px solid #1A3A5C; padding-bottom: 6px; }
                h2 { color: #1A3A5C; margin-top: 24px; }
                .meta { color: #666; font-size: 10pt; }
                table { width: 100%; border-collapse: collapse; margin-top: 12px; }
                td, th { padding: 6px 8px; border-bottom: 1px solid #ddd; text-align: left; }
                .stat-box { display: inline-block; margin-right: 24px; padding: 12px 18px; background: #f4f7fa; border-radius: 4px; }
                .stat-num { font-size: 22pt; font-weight: bold; }
                .stat-label { font-size: 9pt; color: #666; }
            </style>
        </head>
        <body>
            <h1>SecOps Engagement Summary</h1>
            <p class="meta">Generated: {!generatedDate}<br/>Org: {!orgName}</p>

            <h2>Posture at a glance</h2>
            <div class="stat-box"><div class="stat-num">{!totalFindings}</div><div class="stat-label">Total open findings</div></div>
            <div class="stat-box"><div class="stat-num">{!criticalCount}</div><div class="stat-label">Critical</div></div>
            <div class="stat-box"><div class="stat-num">{!highCount}</div><div class="stat-label">High</div></div>
            <div class="stat-box"><div class="stat-num">{!appCount}</div><div class="stat-label">OAuth apps tracked</div></div>

            <h2>Top users by finding count</h2>
            <table>
                <tr><th>User</th><th>Findings</th></tr>
                <apex:repeat value="{!topRisks}" var="row">
                    <tr><td>{!row['name']}</td><td>{!row['findingCount']}</td></tr>
                </apex:repeat>
            </table>

            <p style="margin-top: 32px; font-size: 9pt; color: #888;">Generated by SecOps Health Dashboard</p>
        </body>
    </html>
</apex:page>
